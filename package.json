{
  "name": "mobile",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "build": "expo export --platform web",
    "codegen:api": "openapi-typescript ../contracts/creator-api-v1.yaml -o src/types/generated/api.ts --alphabetize",
    "codegen:check": "npm run codegen:api && git diff --exit-code src/types/generated/api.ts",
    "setup:oauth": "node scripts/setup-oauth.mjs",
    "setup:oauth:redirects": "node scripts/setup-oauth.mjs --print-redirects",
    "logo:extract": "node scripts/extract-logo-png.mjs",
    "prestart": "npm run logo:extract",
    "preweb": "npm run logo:extract",
    "start": "expo start --offline",
    "android": "expo start --android --offline",
    "ios": "expo start --ios --offline",
    "web": "expo start --web --offline",
    "test": "jest --watchAll",
    "test:ci": "jest --ci --coverage --maxWorkers=2 --forceExit",
    "test:e2e": "bash scripts/run-maestro.sh",
    "test:e2e:web": "bash scripts/run-playwright.sh",
    "test:e2e:web:ci": "bash scripts/run-playwright.sh",
    "test:smoke": "bash scripts/run-all-tests.sh",
    "test:e2e:all": "maestro test .maestro/flows/smoke-all.yaml"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/elements": "^2.9.17",
    "@react-navigation/native": "^7.1.8",
    "@tanstack/react-query": "^5.100.10",
    "expo": "~54.0.33",
    "expo-auth-session": "~7.0.11",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.9",
    "expo-device": "^57.0.0",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.23",
    "expo-font": "~14.0.11",
    "expo-linking": "~8.0.11",
    "expo-localization": "~17.0.8",
    "expo-notifications": "^57.0.2",
    "expo-print": "~15.0.8",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.7",
    "expo-sharing": "~14.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.10",
    "html2canvas": "^1.4.1",
    "i18next": "^26.2.0",
    "mammoth": "^1.12.0",
    "pdf-lib": "^1.17.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-i18next": "^17.0.8",
    "react-native": "0.81.5",
    "react-native-draggable-flatlist": "^4.0.3",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "^15.15.5",
    "react-native-web": "~0.21.0",
    "react-native-webview": "13.15.0",
    "react-native-worklets": "0.5.1",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.1.0",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.17",
    "openapi-typescript": "^7.13.0",
    "react-test-renderer": "19.1.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
