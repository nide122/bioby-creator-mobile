{
  "expo": {
    "name": "BioBy Creator",
    "slug": "bioby-creator",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "bioby-creator",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#050706"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "UIBackgroundModes": ["remote-notification"]
      },
      "splash": {
        "image": "./assets/images/splash-icon.png",
        "tabletImage": "./assets/images/splash-icon.png",
        "resizeMode": "contain",
        "backgroundColor": "#050706"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#050706"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "softwareKeyboardLayoutMode": "resize",
      "splash": {
        "image": "./assets/images/splash-icon.png",
        "resizeMode": "contain",
        "backgroundColor": "#050706",
        "mdpi": "./assets/images/splash-icon.png",
        "hdpi": "./assets/images/splash-icon.png",
        "xhdpi": "./assets/images/splash-icon.png",
        "xxhdpi": "./assets/images/splash-icon.png",
        "xxxhdpi": "./assets/images/splash-icon.png"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-localization",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#050706"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "00000000-0000-0000-0000-000000000000"
      }
    },
    "experiments": {
      "typedRoutes": true
    }
  }
}
